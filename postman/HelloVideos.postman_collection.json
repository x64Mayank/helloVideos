          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json?.data?.accessToken) pm.environment.set('accessToken', json.data.accessToken);",
                  "  if (json?.data?.refreshToken) pm.environment.set('refreshToken', json.data.refreshToken);",
                  "  if (json?.data?.user?._id) pm.environment.set('userId', json.data.user._id);",
                  "  if (json?.data?.user?.username) pm.environment.set('username', json.data.user.username);",
                  "  if (json?.data?.user?._id) pm.environment.set('channelId', json.data.user._id);",
                  "  if (json?.data?.user?._id) pm.environment.set('subscriberId', json.data.user._id);",
                  "}"
                ]
              }
            }
